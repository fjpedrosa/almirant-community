{
  "name": "@almirant/database",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema/health": "./src/schema/health.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run --env-file .env.local src/scripts/migrate-with-validation.ts",
    "db:migrate:prod": "NODE_ENV=production bun run --env-file .env src/scripts/migrate-with-validation.ts",
    "db:self-hosted-maintenance": "NODE_ENV=production bun run src/scripts/self-hosted-db-maintenance.ts",
    "db:push": "bun run --env-file .env.local drizzle-kit push",
    "db:push:prod": "bun run --env-file .env drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/seed.ts",
    "db:seed:jobs": "bun run --env-file=.env.local src/seed-job-configurations.ts",
    "db:seed:proxies": "bun run --env-file=.env.local src/seed-proxies.ts",
    "db:seed:templates": "bun run --env-file=.env.local src/seed-board-templates.ts",
    "db:seed:skills": "bun run --env-file=.env.local src/seed-skills.ts",
    "db:seed:bug-analysis": "bun run --env-file=.env.local src/seed-bug-analysis-config.ts",
    "db:seed:auto-debug": "bun run --env-file=.env.local src/seed-auto-debug-config.ts",
    "db:seed:feedback-topic-detectors": "bun run --env-file=.env.local src/seed-feedback-topic-detectors-config.ts",
    "db:delete-proxies": "bun run --env-file=.env.local src/delete-proxies.ts",
    "db:import-proxies": "bun run --env-file=.env.local src/import-brightdata-proxies.ts",
    "db:sync-proxies": "bun run src/sync-proxies-to-prod.ts",
    "db:fix-cross-org-work-items": "bun run src/scripts/fix-cross-org-work-items.ts",
    "db:cleanup-extra-boards": "bun run src/scripts/cleanup-extra-boards.ts",
    "db:verify-worker-timeout-schema": "bun run --env-file .env.local src/scripts/verify-worker-timeout-schema.ts",
    "db:verify-worker-timeout-schema:prod": "bun run --env-file .env src/scripts/verify-worker-timeout-schema.ts",
    "db:repair-agent-job-logs": "bun run --env-file .env.local src/scripts/repair-agent-job-logs.ts",
    "db:repair-agent-job-logs:prod": "bun run --env-file .env src/scripts/repair-agent-job-logs.ts",
    "typecheck": "tsc --noEmit",
    "db:backfill-task-ids": "bun run --env-file .env.local src/backfill-task-ids.ts",
    "db:migrate-board-columns": "bun run --env-file .env.local src/migrate-board-columns.ts",
    "db:backfill-organization": "bun run --env-file .env.local src/scripts/backfill-organization.ts",
    "db:backfill-idea-items": "bun run --env-file .env.local src/scripts/backfill-idea-items.ts",
    "db:migrate-provider-connections": "bun run --env-file .env.local src/scripts/migrate-provider-connections.ts",
    "db:migrate-seed-entity-types": "bun run --env-file .env.local src/scripts/migrate-seed-entity-types.ts",
    "db:migrate-seed-entity-types:prod": "bun run --env-file .env src/scripts/migrate-seed-entity-types.ts",
    "db:migrate-error-log": "bun run --env-file .env.local src/scripts/migrate-error-log.ts",
    "db:backfill:embeddings": "bun run --env-file .env.local src/scripts/backfill-embeddings.ts",
    "backfill:effort-estimations": "bun run src/scripts/backfill-effort-estimations.ts",
    "db:snapshot": "./scripts/db-snapshot.sh",
    "db:restore": "./scripts/db-restore.sh",
    "staging:setup": "bun run src/preview/staging-setup.ts",
    "staging:reset": "bun run src/preview/staging-setup.ts --reset",
    "preview:create": "bun run src/preview/preview-db.ts create",
    "preview:destroy": "bun run src/preview/preview-db.ts destroy",
    "preview:reset": "bun run src/preview/preview-db.ts reset",
    "preview:list": "bun run src/preview/preview-db.ts list",
    "preview:cleanup": "bun run src/preview/preview-db.ts cleanup-stale",
    "preview:stats": "bun run src/preview/preview-db.ts stats",
    "test": "bun test --pass-with-no-tests",
    "test:watch": "bun test --watch --pass-with-no-tests"
  },
  "dependencies": {
    "@almirant/config": "workspace:*",
    "@almirant/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@types/bun": "^1.3.8",
    "@types/node": "^25.2.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.8.0"
  }
}

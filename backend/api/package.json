{
  "name": "@almirant/api",
  "version": "1.0.0",
  "description": "Almirant API",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:prod": "bun --env-file .env.production --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "test": "bun test --pass-with-no-tests",
    "test:watch": "bun test --watch --pass-with-no-tests",
    "type-check": "tsc --noEmit",
    "s3:migrate-legacy-bucket": "bun run --env-file .env scripts/migrate-s3-buckets.ts",
    "discord:register-commands": "bun run src/scripts/register-discord-commands.ts",
    "memory:import-engram": "bun run --env-file .env.local src/scripts/import-engram-memory.ts",
    "resources:forecast:backlog": "bun run --env-file .env src/scripts/recalculate-backlog-resource-forecasts.ts"
  },
  "dependencies": {
    "@almirant/config": "workspace:*",
    "@almirant/canonical-events": "workspace:*",
    "@almirant/database": "workspace:*",
    "@almirant/i18n": "workspace:*",
    "@almirant/remote-agent": "workspace:*",
    "@almirant/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@elysiajs/cors": "^1.2.0",
    "@langchain/anthropic": "^1.3.17",
    "@langchain/core": "^1.1.19",
    "@langchain/openai": "^1.2.5",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@sentry/bun": "^10.39.0",
    "better-auth": "1.4.18",
    "elysia": "^1.2.25",
    "elysia-mcp": "^0.1.1",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.2.18",
    "nodemailer": "^7.0.10",
    "posthog-node": "^5.27.0",
    "resend": "^6.9.2",
    "stripe": "^20.4.0",
    "tweetnacl": "^1.0.3",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/web-push": "^3.6.4",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}

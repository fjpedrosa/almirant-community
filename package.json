{
  "name": "almirant",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend/api",
    "backend/packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "./scripts/dev-local.sh",
    "dev:frontend": "cd frontend && bun run dev",
    "dev:api": "bun run --filter @almirant/api dev",
    "dev:api:prod": "cd backend/api && bun --env-file .env.production --watch src/index.ts",
    "dev:runner": "bun run dev:runner:runtime",
    "dev:runner:runtime": "bun run --filter @almirant/runner dev",
    "dev:runner:stack": "bun run dev:stack:runner",
    "dev:bridge:web": "bun run --filter @almirant/web-bridge dev",
    "dev:bridge:web:stack": "bun run dev:stack:web-bridge",
    "dev:bridge:discord": "bun run --filter @almirant/discord-bridge dev",
    "dev:bridge:discord:stack": "bun run dev:stack:discord-bridge",
    "shim-images:check": "bun run scripts/check-shim-images.ts",
    "skills:validate": "./scripts/validate-skills-consistency.sh",
    "build:frontend": "cd frontend && bun run build",
    "build:api": "bun run --filter @almirant/api build",
    "postinstall": "lefthook install --force || true",
    "test": "bun run test:backend && bun run test:frontend && bun run test:agent-stack",
    "test:frontend": "cd frontend && bun run test",
    "test:backend": "cd backend && bun run test",
    "test:agent-stack": "bun run test:runner && bun run test:web-bridge && bun run test:discord-bridge && bun run test:stream-contracts",
    "test:agent-stack:contracts": "bun run test:stream-contracts",
    "test:runner": "bun run --filter @almirant/runner test",
    "test:web-bridge": "bun run --filter @almirant/web-bridge test",
    "test:discord-bridge": "bun run --filter @almirant/discord-bridge test",
    "test:stream-contracts": "bun run --filter @almirant/stream-consumer test && bun run --filter @almirant/remote-agent test",
    "test:legacy-worker": "cd worker && bun test --pass-with-no-tests",
    "type-check:agent-stack": "bun run type-check:runner && bun run type-check:web-bridge && bun run type-check:discord-bridge && bun run type-check:stream-contracts",
    "type-check:agent-stack:contracts": "bun run type-check:stream-contracts",
    "type-check:runner": "bun run --filter @almirant/runner type-check",
    "type-check:web-bridge": "bun run --filter @almirant/web-bridge type-check",
    "type-check:discord-bridge": "bun run --filter @almirant/discord-bridge type-check",
    "type-check:stream-contracts": "bun run --filter @almirant/stream-consumer type-check && bun run --filter @almirant/remote-agent type-check",
    "type-check:legacy-worker": "cd worker && bun run type-check",
    "db:generate": "bun run --filter @almirant/database db:generate",
    "db:migrate": "bun run --filter @almirant/database db:migrate",
    "db:studio": "bun run --filter @almirant/database db:studio",
    "db:seed": "cd backend && bun run db:seed",
    "db:clear": "cd backend && bun run db:clear",
    "db:snapshot": "cd backend && bun run db:snapshot",
    "db:restore": "cd backend && bun run db:restore",
    "db:clone": "./scripts/db-clone.sh",
    "deploy:agent": "./scripts/deploy-agent.sh",
    "agent:logs": "ssh almirant-runner-1 'cd /opt/almirant/repo/services/runner && docker compose -f docker-compose.prod.yml logs -f --tail=200 runner'",
    "agent:job-logs": "./scripts/agent-job-logs.sh",
    "worktree:cleanup": "./scripts/cleanup-merged-worktrees.sh --base origin/main",
    "worktree:cleanup:dry": "./scripts/cleanup-merged-worktrees.sh --base origin/main --dry-run",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "prod:stack:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build",
    "prod:stack:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down",
    "prod:stack:logs": "docker compose --env-file .env.production -f docker-compose.prod.yml logs -f",
    "dev:stack": "docker compose up -d",
    "dev:stack:runner": "docker compose up -d runner",
    "dev:stack:web-bridge": "docker compose up -d web-bridge",
    "dev:stack:discord-bridge": "docker compose --profile discord-bridge up -d discord-bridge",
    "dev:stack:legacy-worker": "bun run legacy:worker:docker:up",
    "dev:stack:build": "docker compose build",
    "dev:stack:down": "docker compose down",
    "dev:stack:shims": "docker compose --profile shims build",
    "dev:stack:logs": "docker compose logs -f",
    "dev:stack:prod": "docker compose --env-file .env.dev-prod -f docker-compose.yml -f docker-compose.dev-proddb.yml up -d",
    "dev:stack:prod:down": "docker compose --env-file .env.dev-prod -f docker-compose.yml -f docker-compose.dev-proddb.yml down",
    "dev:stack:prod:logs": "docker compose --env-file .env.dev-prod -f docker-compose.yml -f docker-compose.dev-proddb.yml logs -f",
    "legacy:worker:docker:up": "docker compose -f worker/docker-compose.yml --profile local up -d",
    "legacy:worker:docker:down": "docker compose -f worker/docker-compose.yml down",
    "legacy:worker:docker:logs": "docker compose -f worker/docker-compose.yml logs -f",
    "legacy:worker:docker:up:prod": "docker compose -f worker/docker-compose.yml up -d worker",
    "legacy:worker:db:dump": "./worker/scripts/export-prod-dump.sh",
    "smoke-test": "bun run scripts/smoke-test.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10",
    "@tanstack/react-query": "^5.90.19",
    "@uiw/react-md-editor": "^4.0.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.562.0",
    "next": "16.1.4",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}

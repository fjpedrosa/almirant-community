# =============================================================================
# Almirant self-hosted production stack — environment schema
# =============================================================================
# This file is the SOURCE OF TRUTH for every variable consumed by
# docker-compose.prod.yml, scripts/install.sh, and scripts/sync-env.sh.
#
# `almirant upgrade` reads it after `git pull` and adds any missing entries
# to your .env.production using the recipes below. Existing values are
# never overwritten. A backup is written next to the file before any change.
#
# Directive grammar (lines starting with `# @`):
#   @required                       — MUST be present in .env.production
#   @optional                       — may be empty (default)
#   @generate:rand-hex:N            — random N-byte secret as hex
#   @generate:rand-password:N       — random N-char alphanumeric password
#   @generate:uuid                  — random UUID v4
#   @generate:prefix-rand-hex:p:N   — `<p><N-byte hex>` (e.g. alm_sa_<hex>)
#   @derive:stack-dir               — absolute path to the cloned repo
#   @derive:stack-dir:<sub>         — stack-dir joined with <sub>
#   @derive:same-as:VAR             — copy value of another variable
#   @default:<value>                — literal fallback value
#   @prompt:"<message>"             — interactive prompt (install.sh only)
#
# Multiple directives can stack on consecutive `# @` lines preceding a
# `VAR=` entry. Plain `# ` comments are human documentation and are
# preserved verbatim when the schema is rendered into a fresh .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres (data persists in the postgres_prod_data docker volume)
# -----------------------------------------------------------------------------
# @required @default:almirant
POSTGRES_USER=almirant

# @required @generate:rand-password:24
POSTGRES_PASSWORD=

# @required @default:almirant
POSTGRES_DB=almirant

# -----------------------------------------------------------------------------
# Public URL — must match the URL users type in the browser
# -----------------------------------------------------------------------------
# Better Auth validates cookies and CORS against these values on every
# request. NEXT_PUBLIC_SITE_URL is baked into the frontend bundle at build
# time — changing it later requires a frontend rebuild:
#   docker compose -f docker-compose.prod.yml --env-file .env.production \
#     up -d --build --force-recreate frontend backend
#
# @required @prompt:"Public URL where Almirant will be served (no trailing slash)" @default:http://localhost:8080
NEXT_PUBLIC_SITE_URL=http://localhost:8080

# Domain used by the built-in public Caddy proxy. Leave empty when using an
# external reverse proxy or a local-only install.
# @optional
ALMIRANT_DOMAIN=

# Reverse proxy mode selected by installers/operators:
#   none     — expose frontend/backend only on localhost host ports
#   caddy    — run the built-in public Caddy proxy on HTTP_PORT/HTTPS_PORT
#   external — an external Traefik/Nginx/Caddy/Cloudflare tunnel routes traffic
#   local    — run the legacy localhost-only Caddy profile
# @optional @default:none
ALMIRANT_PROXY_MODE=none

# @optional @derive:same-as:NEXT_PUBLIC_SITE_URL
BETTER_AUTH_URL=

# @optional @derive:same-as:NEXT_PUBLIC_SITE_URL
BETTER_AUTH_TRUSTED_ORIGINS=

# Optional in compose — runtime-cors merges this with instance_settings.public_url.
# @optional @derive:same-as:NEXT_PUBLIC_SITE_URL
CORS_ORIGIN=

# Path under SITE_URL where the API is reachable. Leave as /api unless you
# front the stack with a custom router.
# @optional @default:/api
NEXT_PUBLIC_API_URL=/api

# Leave empty to let the frontend derive wss://<same-host>/ws automatically.
# @optional
NEXT_PUBLIC_WS_URL=


# -----------------------------------------------------------------------------
# Required application secrets — DO NOT share or commit
# Regenerating any of these invalidates existing sessions and encrypted values.
# -----------------------------------------------------------------------------
# @required @generate:rand-hex:32
ENCRYPTION_KEY=

# @required @generate:rand-hex:32
BETTER_AUTH_SECRET=

# @required @generate:rand-hex:32
INTERNAL_EMAIL_API_SECRET=

# Service-account key consumed by runner + web-bridge + discord-bridge.
# Must be shaped as `alm_sa_<hex>` — preview-seed.ts validates the prefix
# and rejects keys without it.
# @required @generate:prefix-rand-hex:alm_sa_:32
ALMIRANT_API_KEY=

# -----------------------------------------------------------------------------
# Click-to-update sidecar (auto-injected by `almirant upgrade`)
# -----------------------------------------------------------------------------
# Shared backend ↔ updater sidecar token for the click-to-update banner.
# @required @generate:rand-hex:32
UPDATER_INTERNAL_TOKEN=

# Path to this clone on the host — bind-mounted into the updater so it can
# `git pull` + `docker compose up -d --build` against the same files
# install.sh used. Required by docker-compose.prod.yml.
# @required @derive:stack-dir
ALMIRANT_REPO_PATH=

# Branch the updater pulls from when the admin clicks "Update now".
# @optional @default:main
UPDATER_BRANCH=main

# GitHub Personal Access Token used by the version-check service to poll
# the upstream repo (`almirant-ai/almirant`) and detect new releases. The
# repo is private, so without this token the GitHub API returns 404, the
# poll silently fails, and the "update available" banner never appears.
# Create a PAT with read scope `repo` at https://github.com/settings/tokens.
# @required
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Host ports (bound to 127.0.0.1 — put a reverse proxy in front to expose)
# -----------------------------------------------------------------------------
# Address for direct host port bindings. Keep `127.0.0.1` for host-only
# access. Use `0.0.0.0` or a specific LAN IP for LAN-only installs; that does
# not expose the app to the Internet unless your router/firewall forwards it.
# @optional @default:127.0.0.1
ALMIRANT_BIND_ADDRESS=127.0.0.1

# @optional @default:8080
FRONTEND_HOST_PORT=8080

# @optional @default:8081
BACKEND_HOST_PORT=8081

# Used only when the `with-proxy` profile is enabled.
# @optional @default:8080
PROXY_PORT=8080

# Used only when ALMIRANT_PROXY_MODE=caddy / the `public-proxy` profile is enabled.
# @optional @default:80
HTTP_PORT=80

# Used only when ALMIRANT_PROXY_MODE=caddy / the `public-proxy` profile is enabled.
# @optional @default:443
HTTPS_PORT=443

# -----------------------------------------------------------------------------
# Host paths
# -----------------------------------------------------------------------------
# Where sibling agent containers will mount cloned repos. MUST be a path on
# the HOST filesystem — the docker-proxy creates sibling, not nested,
# containers.
# @optional @derive:stack-dir:data/repos
REPOS_HOST_PATH=

# -----------------------------------------------------------------------------
# Logging / platform toggles
# -----------------------------------------------------------------------------
# @optional @default:info
LOG_LEVEL=info

# Auto-provisioned by preview-seed into instance_settings — leave empty.
# @optional
ALMIRANT_PROJECT_ID=

# @optional @default:false
MCP_INTERNAL_ENABLED=false

# @optional @default:false
ENABLE_BROWSER=false

# @optional @default:false
NIGHTLY_ENABLED=false

# @optional @default:true
WEB_OUTPUT_ENABLED=true

# -----------------------------------------------------------------------------
# Runner capacity profile
# -----------------------------------------------------------------------------
# Keep RAM headroom for the OS, Postgres/Redis, frontend/backend, Docker and
# frontend image builds during upgrades. The CLI installer may suggest a higher
# value on larger hosts.
# @optional @default:2048
RUNNER_RAM_RESERVED_MB=2048

# When enabled, the runner claims jobs based on current MemAvailable and
# forecasted job memory instead of relying only on a fixed slot count.
# @optional @default:true
RUNNER_RAM_BUDGET_ENABLED=true

# CPU/operational safety cap. With RAM budgeting enabled, effective capacity is
# the stricter of this cap and the dynamic RAM budget reported by heartbeat.
# @optional @default:4
MAX_CONCURRENT=4

# -----------------------------------------------------------------------------
# Agent shim images (pinned tags for the runner — only override for testing)
# -----------------------------------------------------------------------------
# @optional @default:almirant-opencode-shim:1.14.31
OPENCODE_IMAGE=almirant-opencode-shim:1.14.31

# @optional @default:almirant-claude-shim:2.1.126
CLAUDE_SHIM_IMAGE=almirant-claude-shim:2.1.126

# @optional @default:almirant-codex-shim:0.128.0
CODEX_SHIM_IMAGE=almirant-codex-shim:0.128.0

# -----------------------------------------------------------------------------
# Discord bridge (only used with `--profile discord-bridge`)
# -----------------------------------------------------------------------------
# @optional
DISCORD_BOT_TOKEN=

# @optional
DISCORD_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Optional AI / integrations / email / storage
# Leave empty unless you need the corresponding integration.
# -----------------------------------------------------------------------------
# @optional
OPENAI_API_KEY=

# @optional @default:gpt-4.1-nano
OPENAI_MODEL=gpt-4.1-nano

# @optional @default:gpt-5-mini
OPENAI_PROMPT_MODEL=gpt-5-mini

# @optional
ANTHROPIC_API_KEY=

# @optional
GOOGLE_CLIENT_ID=

# @optional
GOOGLE_CLIENT_SECRET=

# @optional
GITHUB_APP_ID=

# @optional
GITHUB_PRIVATE_KEY=

# @optional
GITHUB_WEBHOOK_SECRET=

# @optional
GITHUB_CLIENT_ID=

# @optional
GITHUB_CLIENT_SECRET=

# @optional
GITHUB_OAUTH_REDIRECT_URI=

# Sender address for transactional email. Set this to YOUR domain — the
# default would make outbound mail look like it comes from Almirant itself.
# Format: `<Display Name> <user@your-domain.tld>` or just `user@your-domain.tld`.
# @optional
EMAIL_FROM=

# @optional
SMTP_HOST=

# @optional @default:587
SMTP_PORT=587

# @optional @default:false
SMTP_SECURE=false

# @optional
SMTP_USER=

# @optional
SMTP_PASS=

# @optional
RESEND_API_KEY=

# @optional
S3_ACCESS_KEY=

# @optional
S3_SECRET_KEY=

# @optional @default:eu-central
S3_REGION=eu-central

# @optional
S3_BUCKET=

# @optional
S3_PRIVATE_BUCKET=

# @optional
S3_ENDPOINT=

# Local fallback storage used when S3 is not configured.
# In docker-compose.prod.yml this path is backed by the almirant_prod_storage
# volume, so project landing screenshots survive backend container recreation.
# @optional @default:/app/storage
ALMIRANT_STORAGE_DIR=/app/storage

# @optional
POSTHOG_API_KEY=

# @optional @default:https://eu.i.posthog.com
POSTHOG_HOST=https://eu.i.posthog.com

# @optional
SENTRY_DSN=

# @optional
SENTRY_AUTH_TOKEN=

# @optional
SENTRY_ORG=

# @optional
SENTRY_PROJECT_FRONTEND=

# @optional
SENTRY_PROJECT_BACKEND=

{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@almirant/canonical-events": ["../../backend/packages/canonical-events/src/index.ts"],
      "@almirant/remote-agent": ["../../backend/packages/remote-agent/src/index.ts"],
      "@almirant/shared": ["../../backend/packages/shared/src/index.ts"],
      "@almirant/stream-consumer": ["../../backend/packages/stream-consumer/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src"]
}

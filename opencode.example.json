{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "model": "zai-coding-plan/glm-5.2",
  "small_model": "zai-coding-plan/glm-4.7-flashx",
  "autoupdate": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "write": "allow"
  },
  "mcp": {
    "almirant": {
      "type": "remote",
      "url": "https://api.almirant.ai/mcp?projectId=YOUR_PROJECT_ID",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer YOUR_API_KEY"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-from-cwd"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/YOUR_USER/Documents",
        "/Users/YOUR_USER/Desktop",
        "/Users/YOUR_USER/Downloads",
        "/Users/YOUR_USER/Projects"
      ],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      ".next/**",
      "backend/api/dist/**"
    ]
  }
}

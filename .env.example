# =============================================================================
# Almirant local/self-hosted stack
# =============================================================================
# Copy to .env before running `docker compose up -d --build`.
# The defaults below are intentionally usable in local Docker as-is.
# Change the secrets before exposing anything outside your machine.
# For the compiled production + tailnet stack, use `.env.production.example`
# and `docker-compose.prod.yml` instead.
# =============================================================================

# -----------------------------------------------------------------------------
# Core database / cache
# -----------------------------------------------------------------------------
POSTGRES_DB=almirant
POSTGRES_USER=almirant
POSTGRES_PASSWORD=almirant_dev_password
POSTGRES_PORT=5432
REDIS_PORT=6379
DATABASE_URL=postgresql://almirant:almirant_dev_password@postgres:5432/almirant

# -----------------------------------------------------------------------------
# Service ports
# -----------------------------------------------------------------------------
WEB_PORT=3000
API_PORT=3001
RUNNER_PORT=3002
DISCORD_BRIDGE_PORT=3003
WEB_BRIDGE_PORT=3004

# -----------------------------------------------------------------------------
# Frontend / auth
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,https://frontend.almirant.orb.local
BETTER_AUTH_SECRET=almirant-local-dev-better-auth-secret-2026
INTERNAL_EMAIL_API_SECRET=almirant-local-dev-email-secret-2026
CORS_ORIGIN=http://localhost:3000,https://frontend.almirant.orb.local

# -----------------------------------------------------------------------------
# Runner / bridges
# -----------------------------------------------------------------------------
# Well-known dev key created by backend/packages/database/src/preview/preview-seed.ts
ALMIRANT_API_KEY=alm_sa_03a9fd877e5dde3cdc283b0a7c28b6bc19d6206303feedff2daab4f77d28962e
LOG_LEVEL=info
ENABLE_BROWSER=false
NIGHTLY_ENABLED=false
WEB_OUTPUT_ENABLED=true
OPENCODE_IMAGE=almirant-opencode-shim:1.17.20
CLAUDE_SHIM_IMAGE=almirant-claude-shim:2.1.209
CODEX_SHIM_IMAGE=almirant-codex-shim:0.144.4

# -----------------------------------------------------------------------------
# Initial setup
# -----------------------------------------------------------------------------
# The local stack no longer creates a demo user automatically.
# On first boot, open the app and create the initial admin account at /signup.

# -----------------------------------------------------------------------------
# Optional AI providers
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
OPENAI_PROMPT_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Optional OAuth / integrations
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_APP_ID=
# Base64-encoded PEM private key if you enable the GitHub App integration.
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
NEXT_PUBLIC_GITHUB_APP_SLUG=

# -----------------------------------------------------------------------------
# Optional email delivery
# -----------------------------------------------------------------------------
EMAIL_FROM=Almirant <no-reply@almirant.ai>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Optional storage / telemetry / misc
# -----------------------------------------------------------------------------
# Local fallback storage used when S3 is not configured.
ALMIRANT_STORAGE_DIR=/app/storage
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central
S3_BUCKET=
S3_PRIVATE_BUCKET=
S3_ENDPOINT=
# Local fallback storage used when S3 is not configured.
ALMIRANT_STORAGE_DIR=/app/storage
ENCRYPTION_KEY=
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT_FRONTEND=
SENTRY_PROJECT_BACKEND=
